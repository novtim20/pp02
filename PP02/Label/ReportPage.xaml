<Page x:Class="PP02.Label.ReportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:PP02.Label"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1000"
      Title="Формирование отчета">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Фильтры -->
        <Border Grid.Row="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Роль -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,10">
                    <TextBlock Text="Роль:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="RoleFilter" Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem Content="Все" IsSelected="True"/>
                        <ComboBoxItem Content="Студент"/>
                        <ComboBoxItem Content="Преподаватель"/>
                    </ComboBox>
                </StackPanel>

                <!-- Специальность -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                    <TextBlock Text="Специальность:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="SpecialtyFilter" Width="200" HorizontalAlignment="Left" DisplayMemberPath="Name"/>
                </StackPanel>

                <!-- Год выпуска -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,10">
                    <TextBlock Text="Год выпуска:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="GraduationYearFilter" Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem Content="Все" IsSelected="True"/>
                    </ComboBox>
                </StackPanel>

                <!-- Пол -->
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                    <TextBlock Text="Пол:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="GenderFilter" Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem Content="Все" IsSelected="True"/>
                        <ComboBoxItem Content="Мужской"/>
                        <ComboBoxItem Content="Женский"/>
                    </ComboBox>
                </StackPanel>

                <!-- Образование -->
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,15,10">
                    <TextBlock Text="Образование:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="EducationFilter" Width="200" HorizontalAlignment="Left" DisplayMemberPath="Name"/>
                </StackPanel>

                <!-- Социальное происхождение -->
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                    <TextBlock Text="Соц. происхождение:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="SocialOriginFilter" Width="200" HorizontalAlignment="Left" DisplayMemberPath="Name"/>
                </StackPanel>

                <!-- Поиск по ФИО -->
                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,0">
                    <TextBlock Text="Поиск по ФИО:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="FullNameSearch" Width="400" HorizontalAlignment="Left" TextChanged="FullNameSearch_TextChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Предпросмотр данных -->
        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Предпросмотр данных:" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                <DataGrid Grid.Row="1" x:Name="PreviewDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>
                        <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="100"/>
                        <DataGridTextColumn Header="Специальность" Binding="{Binding SpecialtyName}" Width="150"/>
                        <DataGridTextColumn Header="Группа" Binding="{Binding GroupName}" Width="80"/>
                        <DataGridTextColumn Header="Год выпуска" Binding="{Binding GraduationYear}" Width="80"/>
                        <DataGridTextColumn Header="Пол" Binding="{Binding Gender}" Width="80"/>
                        <DataGridTextColumn Header="Образование" Binding="{Binding EducationName}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Кнопки экспорта -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="📊 Экспорт в Excel" Width="150" Height="40" Margin="0,0,15,0"
                    Click="ExportToExcel_Click" Background="#217346" Foreground="White" FontWeight="Bold"/>
            <Button Content="📄 Экспорт в Word" Width="150" Height="40" Margin="15,0,0,0"
                    Click="ExportToWord_Click" Background="#2B579A" Foreground="White" FontWeight="Bold"/>
            <TextBlock x:Name="StatusMessage" VerticalAlignment="Center" Margin="20,0,0,0" Foreground="Green"/>
        </StackPanel>
    </Grid>
</Page>