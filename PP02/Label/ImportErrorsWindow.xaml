<Window x:Class="PP02.Label.ImportErrorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="❌ Ошибки импорта" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        KeyDown="Window_KeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" CornerRadius="5" Padding="15"
                BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="⚠️ Ошибки при импорте данных"
                           FontSize="20" FontWeight="Bold" Foreground="#D32F2F"/>
                <TextBlock x:Name="ErrorCountText"
                           Text="Всего ошибок: 0"
                           FontSize="14" Foreground="#666" Margin="0,5,0,0"/>
                <TextBlock Text="Ниже приведен список записей, которые не удалось импортировать. Исправьте ошибки в исходном файле и попробуйте снова."
                           FontSize="12" Foreground="#888" Margin="0,10,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Таблица ошибок -->
        <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="15"
                BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,15">
            <DataGrid x:Name="ErrorsDataGrid" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="True" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="#DDD" BorderThickness="0"
                      RowHeight="80">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№ строки" Binding="{Binding RowNumber}" Width="80"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>
                    <DataGridTextColumn Header="Ошибка" Binding="{Binding ErrorMessage}" Width="250"/>
                    <DataGridTextColumn Header="Детали" Binding="{Binding ErrorDetails}" Width="300"/>
                    <DataGridTemplateColumn Header="Действия" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="📋 Копировать"
                                        Click="CopyErrorButton_Click"
                                        Background="#2196F3" Foreground="White"
                                        BorderThickness="0" Padding="5,3"
                                        ToolTip="Скопировать информацию об ошибке"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Кнопка закрытия -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CloseButton" Content="✅ Закрыть" Width="120" Height="40"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>