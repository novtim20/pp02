<Page x:Class="PP02.Label.EducationDocumentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:PP02.Label"
      xmlns:item="clr-namespace:PP02.Label.Item"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="Документы об образовании">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="10" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="📚 Документы об образовании" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox x:Name="TxtSearch" Width="300" Height="25"
                             TextChanged="TxtSearch_TextChanged"
                             ToolTip="Поиск по ФИО получателя, серии и номеру документа"/>
                    <TextBlock Text="🔍 Поиск" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#666"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Button Content="➕ Добавить документ" Click="BtnAddDocument_Click"
                            Background="#4CAF50" Foreground="White" FontWeight="Bold"
                            Padding="10,5" Margin="0,0,10,0"/>
                    <Button Content="🔄 Обновить" Click="BtnRefresh_Click"
                            Background="#2196F3" Foreground="White" FontWeight="Bold"
                            Padding="10,5"/>
                    <TextBlock x:Name="TxtCount" Text="" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#666"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Список документов -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" x:Name="ScrollDocuments">
            <ItemsControl x:Name="ItemsDocuments">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <item:EducationDocumentItem DocumentData="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Заглушка при отсутствии данных -->
        <TextBlock Grid.Row="1" Text="Нет документов об образовании"
                   FontSize="16" Foreground="#999"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   x:Name="TxtNoData" Visibility="Collapsed"/>
    </Grid>
</Page>