<UserControl x:Class="PP02.Label.Item.PersonItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PP02.Label.Item"
 mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="800">

    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Margin="5" Background="White">
        <StackPanel>

            <!-- === КРАТКИЙ ВИД (Всегда виден) === -->
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ФИО, Год, Группа, Специальность -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtFio" FontWeight="Bold" FontSize="14" Text="ФИО"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock x:Name="TxtGradYear" Text="Год: ----" Foreground="#666" FontSize="11"/>
                        <TextBlock Text=" | " Foreground="#666" FontSize="11"/>
                        <TextBlock x:Name="TxtGroup" Text="Группа: ---" Foreground="#666" FontSize="11"/>
                        <TextBlock Text=" | " Foreground="#666" FontSize="11"/>
                        <TextBlock x:Name="TxtSpecialty" Text="Специальность" Foreground="#0066CC" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- Кнопка раскрытия -->
                <Button  x:Name="BtnExpand" Grid.Column="1" Content="▼" Width="30" Height="30"
                        Click="BtnExpand_Click" ToolTip="Развернуть"/>

                <!-- Кнопка сохранения (скрыта по умолчанию) -->
                <Button Grid.Column="2" Content="💾 Сохранить" Width="100" Height="30"
                        Background="#4CAF50" Foreground="White" FontWeight="Bold"
                        x:Name="BtnSave" Visibility="Collapsed" Click="BtnSave_Click" Margin="5,0,0,0"/>

                <!-- Кнопка отмены -->
                <Button Grid.Column="3" Content="✕" Width="30" Height="30"
                        x:Name="BtnCancel" Visibility="Collapsed" Click="BtnCancel_Click" Margin="5,0,0,0" ToolTip="Отменить"/>

                <!-- Кнопка удаления -->
                <Button Grid.Column="4" Content="🗑" Width="30" Height="30"
                        x:Name="BtnDelete" Background="#FF5252" Foreground="White" FontWeight="Bold"
                        Click="BtnDelete_Click" Margin="5,0,0,0" ToolTip="Удалить студента"/>

                <!-- Кнопка экспорта отчета -->
                <Button Grid.Column="5" Content="📄" Width="30" Height="30"
                        x:Name="BtnExportReport" Background="#2196F3" Foreground="White" FontWeight="Bold"
                        Click="BtnExportReport_Click" Margin="5,0,0,0" ToolTip="Экспорт в отчет о выпускнике"/>
            </Grid>

            <!-- === РАСКРЫВАЕМАЯ ПАНЕЛЬ С РЕДАКТИРОВАНИЕМ === -->
            <Expander x:Name="ExpDetails" Visibility="Collapsed" Expanded="ExpDetails_Expanded">
                <Expander.Header>
                    <TextBlock Text="Подробная информация (режим редактирования)" FontStyle="Italic" Foreground="#666"/>
                </Expander.Header>

                <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Левая колонка -->
                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="5">
                            <TextBlock Text="Роль:" FontWeight="Bold" FontSize="11"/>
                            <ComboBox x:Name="CmbRole" Height="25">
                                <ComboBoxItem Content="Студент"/>
                                <ComboBoxItem Content="Преподаватель"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="5">
                            <TextBlock Text="Год выпуска:" FontWeight="Bold" FontSize="11"/>
                            <TextBox x:Name="TxtEditGradYear" Height="25"/>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="2" Margin="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="Группа:" FontWeight="Bold" FontSize="11"/>
                                    <ComboBox x:Name="CmbGroup" Height="25" IsEditable="True"
                                              SelectedValuePath="Id"
                                              StaysOpenOnEdit="True">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Code}" FontWeight="Bold" Width="80"/>
                                                    <TextBlock Text="{Binding ShortName}" Margin="5,0" Width="150"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="3" Margin="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="Специальность:" FontWeight="Bold" FontSize="11"/>
                                    <ComboBox x:Name="CmbSpecialty" Height="25" SelectedValuePath="Id"
                                              IsEditable="True" StaysOpenOnEdit="True">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Code}" FontWeight="Bold" Width="80"/>
                                                    <TextBlock Text="{Binding ShortName}" Margin="5,0" Width="150"/>
                                                    <TextBlock Text="{Binding Name}" Foreground="#666" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                            </Grid>
                        </StackPanel>

                        <!-- Центральная колонка -->
                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="5">
                            <TextBlock Text="Пол:" FontWeight="Bold" FontSize="11"/>
                            <ComboBox x:Name="CmbGender" Height="25">
                                <ComboBoxItem Content="Мужской"/>
                                <ComboBoxItem Content="Женский"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="1" Margin="5">
                            <TextBlock Text="Год рождения:" FontWeight="Bold" FontSize="11"/>
                            <TextBox x:Name="TxtEditBirthYear" Height="25"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="2" Margin="5">
                            <TextBlock Text="Место рождения:" FontWeight="Bold" FontSize="11"/>
                            <TextBox x:Name="TxtEditBirthPlace" Height="25"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="3" Margin="5">
                            <TextBlock Text="Национальность:" FontWeight="Bold" FontSize="11"/>
                            <TextBox x:Name="TxtEditNationality" Height="25"/>
                        </StackPanel>

                        <!-- Правая колонка -->
                        <StackPanel Grid.Column="2" Grid.Row="0" Margin="5">
                            <TextBlock Text="Образование:" FontWeight="Bold" FontSize="11"/>
                            <ComboBox x:Name="CmbEducation" Height="25" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Grid.Row="1" Margin="5">
                            <TextBlock Text="Соц. происхождение:" FontWeight="Bold" FontSize="11"/>
                            <ComboBox x:Name="CmbSocialOrigin" Height="25" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Grid.Row="2" Margin="5">
                            <TextBlock Text="Соц. положение:" FontWeight="Bold" FontSize="11"/>
                            <ComboBox x:Name="CmbSocialStatus" Height="25" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Grid.Row="3" Margin="5">
                            <TextBlock Text="Партийность:" FontWeight="Bold" FontSize="11"/>
                            <ComboBox x:Name="CmbParty" Height="25" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                        </StackPanel>

                        <!-- Адрес и остальные поля на всю ширину -->
                        <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="4" Margin="5">
                            <TextBlock Text="Домашний адрес:" FontWeight="Bold" FontSize="11"/>
                            <TextBox x:Name="TxtEditAddress" Height="25"/>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="5" Margin="5">
                            <TextBlock Text="Где работал после:" FontWeight="Bold" FontSize="11"/>
                            <TextBox x:Name="TxtEditWorkAfter" Height="25"/>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="6" Margin="5">
                            <TextBlock Text="Источник:" FontWeight="Bold" FontSize="11"/>
                            <TextBox x:Name="TxtEditSource" Height="25"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Expander>
        </StackPanel>
    </Border>
</UserControl>