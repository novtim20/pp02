<Page x:Class="PP02.Label.authorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PP02.Label"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="authorization">

    <Grid Background="#AAAA">
        <Border Background="White" 
            CornerRadius="10" 
            Margin="200,100,200,100"
            Padding="30"
            HorizontalAlignment="Center" 
            VerticalAlignment="Center">

            <!-- Тень -->
            <Border.Effect>
                <DropShadowEffect Color="#888888" BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
            </Border.Effect>

            <StackPanel Width="300">
                <!-- Заголовок -->
                <TextBlock Text="Вход в систему" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,30"
                       Foreground="#333"/>

                <!-- Логин -->
                <TextBlock Text="Логин" FontSize="14" Margin="0,0,0,5" Foreground="#555"/>
                <TextBox x:Name="LoginTextBox" Text="admin"
                     Height="35" 
                     Padding="10,0,0,0"
                     FontSize="14"
                     BorderBrush="#CCC"
                     BorderThickness="1"
                     Margin="0,0,0,15"/>

                <!-- Пароль -->
                <TextBlock Text="Пароль" FontSize="14" Margin="0,0,0,5" Foreground="#555"/>
                <PasswordBox x:Name="PasswordBox" 
                         Height="35" 
                         Padding="10,0,0,0"
                         FontSize="14"
                         BorderBrush="#CCC"
                         BorderThickness="1"
                         Margin="0,0,0,20"/>

                <!-- Кнопка Вход -->
                <Button Content="Вход" 
                    Height="40"
                    FontSize="16"
                    FontWeight="Medium"
                    Background="#007ACC"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,0,10"
                    Click="LoginButton_Click"/>

                <!-- Сообщение об ошибке -->
                <TextBlock x:Name="ErrorTextBlock" 
                       Text="" 
                       Foreground="Red" 
                       FontSize="12" 
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
