<Page x:Class="PP02.Label.StudentsListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:PP02.Label"
      xmlns:item="clr-namespace:PP02.Label.Item"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="1100"
      Background="#F5F5F5"
      Title="Списки студентов">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ЗАГОЛОВОК -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📚 Списки студентов"
                       FontSize="24" FontWeight="Bold" Foreground="#333"/>
            <TextBlock Text="Выберите действие для работы со студентами"
                       FontSize="14" Foreground="#666" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- КНОПКИ НАВИГАЦИИ -->
        <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="20"
                BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,20">
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- 🔹 Добавить студента -->
                <Button Content="➕ Добавить студента"
                        Width="200" Height="60"
                        Background="#4CAF50" Foreground="White"
                        FontWeight="Bold" FontSize="14"
                        BorderThickness="0"
                        Click="AddStudentButton_Click"
                        Margin="10"/>

                <!-- 🔹 Документы об образовании -->
                <Button Content="📄 Документы об образовании"
                        Width="200" Height="60"
                        Background="#2196F3" Foreground="White"
                        FontWeight="Bold" FontSize="14"
                        BorderThickness="0"
                        Click="EducationDocumentsButton_Click"
                        Margin="10"/>

                <!-- 🔹 Импорт из Excel -->
                <Button Content="📊 Импорт из Excel"
                        Width="200" Height="60"
                        Background="#FF9800" Foreground="White"
                        FontWeight="Bold" FontSize="14"
                        BorderThickness="0"
                        Click="ImportExcelButton_Click"
                        Margin="10"/>

                <!-- 🔹 Отчёты -->
                <Button Content="📈 Отчёты"
                        Width="200" Height="60"
                        Background="#9C27B0" Foreground="White"
                        FontWeight="Bold" FontSize="14"
                        BorderThickness="0"
                        Click="ReportButton_Click"
                        Margin="10"/>

                <!-- 🔹 Специальности и группы -->
                <Button Content="🎓 Специальности и группы"
                        Width="200" Height="60"
                        Background="#00BCD4" Foreground="White"
                        FontWeight="Bold" FontSize="14"
                        BorderThickness="0"
                        Click="SpecialtyGroupsButton_Click"
                        Margin="10"/>

                <!-- 🔹 Поиск -->
                <Button Content="🔍 Поиск студентов"
                        Width="200" Height="60"
                        Background="#E91E63" Foreground="White"
                        FontWeight="Bold" FontSize="14"
                        BorderThickness="0"
                        Click="SearchButton_Click"
                        Margin="10"/>

            </WrapPanel>
        </Border>

        <!-- СПИСОК СТУДЕНТОВ -->
        <Border Grid.Row="2" Background="White" CornerRadius="5" Padding="20"
                BorderBrush="#DDD" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="👥 Список студентов"
                           FontSize="18" FontWeight="Bold" Foreground="#333"
                           Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="StudentsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <item:PersonItem PersonData="{Binding}" Margin="0,0,0,10"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>