<Page x:Class="PP02.Label.ReportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:PP02.Label"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1000"
      Title="Формирование отчета">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Фильтры -->
        <Border Grid.Row="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Роль -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,10">
                    <TextBlock Text="Роль:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbRole" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Специальность -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                    <TextBlock Text="Специальность:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbSpecialty" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Образование -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,10">
                    <TextBlock Text="Образование:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbEducation" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Социальное происхождение -->
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                    <TextBlock Text="Соц. происхождение:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbOrigin" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Социальный статус -->
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,15,10">
                    <TextBlock Text="Соц. статус:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbStatus" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Партийность -->
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                    <TextBlock Text="Партийность:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbParty" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Поиск по ФИО -->
                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,0">
                    <TextBlock Text="Поиск по ФИО:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TbNameSearch" Width="400" HorizontalAlignment="Left" TextChanged="TbNameSearch_TextChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Предпросмотр данных -->
        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Предпросмотр данных:" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                <TextBlock x:Name="LbCount" Grid.Row="0" Text="Найдено записей: 0" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" HorizontalAlignment="Right"/>

                <ItemsControl x:Name="ResultsItemsControl" Grid.Row="1">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,5">
                                <StackPanel>
                                    <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding Role}" FontStyle="Italic"/>
                                    <TextBlock Text="{Binding SpecialtyName}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- Кнопки экспорта -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="📊 Экспорт в Excel" Width="150" Height="40" Margin="0,0,15,0"
                    Click="BtnExportExcel_Click" Background="#217346" Foreground="White" FontWeight="Bold"/>
            <Button Content="📄 Экспорт в Word" Width="150" Height="40" Margin="15,0,0,0"
                    Click="BtnExportWord_Click" Background="#2B579A" Foreground="White" FontWeight="Bold"/>
            <Button Content="Применить фильтры" Width="150" Height="40" Margin="15,0,0,0"
                    Click="FilterButton_Click" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Page>