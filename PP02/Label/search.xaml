<Page x:Class="PP02.Label.search"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:PP02.Label" xmlns:local1="clr-namespace:PP02.Label.Item"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="1100"
      Background="#F5F5F5"
      Title="Поиск студентов"
      Loaded="Page_Loaded">

    <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Фильтры -->
                <RowDefinition Height="*"/>
                <!-- Результаты -->
            </Grid.RowDefinitions>

            <!-- === ВЕРХНЯЯ ЧАСТЬ: ФИЛЬТРЫ === -->
            <StackPanel Grid.Row="0" Margin="20">

                <!-- 🔹 ОСНОВНЫЕ ДАННЫЕ (Всегда видны) -->
                <Border Background="White" CornerRadius="5" Padding="20" Margin="0,0,0,10"
                        BorderBrush="#DDD" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="3" Text="📋 Основные данные"
                                   FontSize="16" FontWeight="Bold" Margin="0,0,0,15"
                                   Foreground="#333"/>

                        <!-- ФИО -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,15">
                            <TextBlock Text="Фамилия Имя Отчество" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                            <TextBox x:Name="FullNameTextBox" Height="35" Padding="8,0,0,0"
                                     BorderBrush="#DDD" BorderThickness="1"
                                     TextChanged="FilterTextBox_TextChanged"/>
                        </StackPanel>

                        <!-- Студент -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,15">
                            <TextBlock Text="Студент" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                            <ComboBox x:Name="IsStudentComboBox" Height="35"
                                      BorderBrush="#DDD" BorderThickness="1"
                                      SelectionChanged="FilterComboBox_SelectionChanged">
                                <ComboBoxItem Content="Все" IsSelected="True"/>
                                <ComboBoxItem Content="Да"/>
                                <ComboBoxItem Content="Нет"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Группа -->
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="Группа" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <ComboBox x:Name="GroupComboBox" Height="35"
                                              BorderBrush="#DDD" BorderThickness="1"
                                              IsEditable="True"
                                              IsTextSearchEnabled="True"
                                              TextSearch.TextPath="Code"
                                              SelectionChanged="GroupComboBox_SelectionChanged">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontWeight="Bold" Text="{Binding Code}"/>
                                                    <TextBlock Text=" [" Foreground="#888"/>
                                                    <TextBlock Text="{Binding ShortName}" Foreground="#888"/>
                                                    <TextBlock Text="]" Foreground="#888"/>
                                                    <TextBlock Text=" - " Foreground="#888"/>
                                                    <TextBlock Text="{Binding SpecialtyName}" FontStyle="Italic"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="5,0,0,0">
                                    <Button Content="➕" Width="35" Height="28"
                                            Background="#2196F3" Foreground="White"
                                            FontWeight="Bold" BorderThickness="0"
                                            Click="AddGroupButton_Click"
                                            ToolTip="Добавить группу"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Год выпуска + Период -->
                        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,10,15"
                                BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Background="#F9F9F9">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                    <TextBlock Text="Год выпуска" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <DatePicker x:Name="GraduationYearDatePicker" Height="35"
                                                BorderBrush="#DDD" BorderThickness="1" Background="White"
                                                Padding="8,0,0,0"
                                                SelectedDateChanged="FilterDatePicker_SelectedDateChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" MinWidth="280">
                                    <CheckBox x:Name="PeriodCheckBox" Content="Поиск по периоду"
                                              FontSize="12" Margin="0,0,0,8" Foreground="#555"
                                              HorizontalAlignment="Right"
                                              Checked="PeriodCheckBox_Changed" Unchecked="PeriodCheckBox_Changed"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Окончание" FontSize="12" Margin="0,0,5,0"
                                                   VerticalAlignment="Center" Foreground="#555"/>
                                        <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1"
                                                CornerRadius="3" Background="#E8E8E8">
                                            <DatePicker x:Name="EndDatePicker" BorderThickness="0"
                                                        Height="33" Padding="5,0,0,0" IsEnabled="False" Width="150"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Специальность -->
                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="Специальность" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <ComboBox x:Name="SpecialtyComboBox" Height="35"
                                              BorderBrush="#DDD" BorderThickness="1"
                                              IsEditable="True"
                                              IsTextSearchEnabled="True"
                                              TextSearch.TextPath="Name"
                                              SelectionChanged="FilterComboBox_SelectionChanged">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="5,0,0,0">
                                    <Button Content="➕" Width="35" Height="28"
                                            Background="#9C27B0" Foreground="White"
                                            FontWeight="Bold" BorderThickness="0"
                                            Click="AddSpecialtyButton_Click"
                                            ToolTip="Добавить специальность"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 🔹 РАСШИРЕННЫЙ ПОИСК (Скрыт под кнопкой) -->
                <Expander x:Name="AdvancedSearchExpander" Margin="0,0,0,10"
                          Background="White" BorderBrush="#DDD" BorderThickness="1"
                          Header="🔍 Расширенный поиск"
                          Foreground="#555" FontSize="14" FontWeight="Bold"
                          Padding="15" IsExpanded="False">
                    <StackPanel Margin="10">

                        <!-- Личные данные -->
                        <Border Background="#FAFAFA" CornerRadius="5" Padding="15" Margin="0,0,0,10"
                                BorderBrush="#EEE" BorderThickness="1">
                            <!-- 🔧 ИСПРАВЛЕНО: Добавлена 3-я строка (Height="Auto") -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <!-- 🔧 НОВАЯ СТРОКА -->
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.ColumnSpan="3" Text="Личные данные"
                                           FontSize="14" FontWeight="Bold" Margin="0,0,0,15"
                                           Foreground="#444"/>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,15">
                                    <TextBlock Text="Пол" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <ComboBox x:Name="GenderComboBox" Height="35" BorderBrush="#DDD" BorderThickness="1"
                                              SelectionChanged="FilterComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Все" IsSelected="True"/>
                                        <ComboBoxItem Content="М"/>
                                        <ComboBoxItem Content="Ж"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,15">
                                    <TextBlock Text="Национальность" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <TextBox x:Name="NationalityTextBox" Height="35" Padding="8,0,0,0"
                                             BorderBrush="#DDD" BorderThickness="1"
                                             TextChanged="FilterTextBox_TextChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,15">
                                    <TextBlock Text="Год рождения" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <TextBox x:Name="BirthYearTextBox" Height="35" Padding="8,0,0,0"
                                             BorderBrush="#DDD" BorderThickness="1"
                                             TextChanged="FilterTextBox_TextChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,15">
                                    <TextBlock Text="Партийность" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <ComboBox x:Name="PartyComboBox" Height="35" BorderBrush="#DDD" BorderThickness="1"
                                              SelectedValuePath="Id" DisplayMemberPath="Name"
                                              SelectionChanged="FilterComboBox_SelectionChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,10,15">
                                    <TextBlock Text="Место рождения" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <TextBox x:Name="BirthPlaceTextBox" Height="35" Padding="8,0,0,0"
                                             BorderBrush="#DDD" BorderThickness="1"
                                             TextChanged="FilterTextBox_TextChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,15">
                                    <TextBlock Text="Образование" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <ComboBox x:Name="EducationComboBox" Height="35" BorderBrush="#DDD" BorderThickness="1"
                                              SelectedValuePath="Id" DisplayMemberPath="Name"
                                              SelectionChanged="FilterComboBox_SelectionChanged"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Социальные данные -->
                        <Border Background="#FAFAFA" CornerRadius="5" Padding="15" Margin="0,0,0,10"
                                BorderBrush="#EEE" BorderThickness="1">
                            <!-- 🔧 ИСПРАВЛЕНО: Добавлена 3-я строка (Height="Auto") -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <!-- 🔧 НОВАЯ СТРОКА -->
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.ColumnSpan="3" Text="Социальные данные"
                                           FontSize="14" FontWeight="Bold" Margin="0,0,0,15"
                                           Foreground="#444"/>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,15">
                                    <TextBlock Text="Соц.пол." FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <TextBox x:Name="SocialPositionTextBox" Height="35" Padding="8,0,0,0"
                                             BorderBrush="#DDD" BorderThickness="1"
                                             TextChanged="FilterTextBox_TextChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,15">
                                    <TextBlock Text="Где работал посл.вр." FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <TextBox x:Name="LastWorkplaceTextBox" Height="35" Padding="8,0,0,0"
                                             BorderBrush="#DDD" BorderThickness="1"
                                             TextChanged="FilterTextBox_TextChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,15">
                                    <TextBlock Text="Соц.проис." FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <ComboBox x:Name="SocialOriginComboBox" Height="35" BorderBrush="#DDD" BorderThickness="1"
                                              SelectedValuePath="Id" DisplayMemberPath="Name"
                                              SelectionChanged="FilterComboBox_SelectionChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,15">
                                    <TextBlock Text="Откуда прибыл, адрес" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <TextBox x:Name="AddressTextBox" Height="35" Padding="8,0,0,0"
                                             BorderBrush="#DDD" BorderThickness="1"
                                             TextChanged="FilterTextBox_TextChanged"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Документы -->
                        <Border Background="#FAFAFA" CornerRadius="5" Padding="15" Margin="0,0,0,10"
                                BorderBrush="#EEE" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.ColumnSpan="2" Text="Документы"
                                           FontSize="14" FontWeight="Bold" Margin="0,0,0,15"
                                           Foreground="#444"/>

                                <Border Grid.Row="1" Grid.Column="0" Margin="0,0,10,15"
                                        BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Background="White">
                                    <Grid Margin="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                            <TextBlock Text="Дата выдачи диплома" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="3" Background="White">
                                                <DatePicker x:Name="DiplomaStartDatePicker" BorderThickness="0"
                                                            Height="35" Padding="8,0,0,0"
                                                            SelectedDateChanged="FilterDatePicker_SelectedDateChanged"/>
                                            </Border>
                                        </StackPanel>
                                        <Grid Grid.Column="1">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <CheckBox x:Name="DiplomaPeriodCheckBox" Grid.Row="0"
                                                      Content="Поиск по периоду" FontSize="12" Margin="0,0,0,8" Foreground="#555"
                                                      HorizontalAlignment="Right"
                                                      Checked="DiplomaPeriodCheckBox_Changed" Unchecked="DiplomaPeriodCheckBox_Changed"/>
                                            <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1"
                                                    CornerRadius="3" Background="#E8E8E8">
                                                <DatePicker x:Name="DiplomaEndDatePicker" BorderThickness="0"
                                                            Height="35" Padding="8,0,0,0" IsEnabled="False" Width="180"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,15">
                                    <TextBlock Text="Источник" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <TextBox x:Name="SourceTextBox" Height="35" Padding="8,0,0,0"
                                             BorderBrush="#DDD" BorderThickness="1"
                                             TextChanged="FilterTextBox_TextChanged"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Expander>

                <!-- 🔹 КНОПКИ ДЕЙСТВИЙ -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,20">
                    <Button Content="🗂 Группы специальностей" Width="200" Height="45" FontSize="16" FontWeight="Bold"
                            Background="#607D8B" Foreground="White" BorderThickness="0"
                            Margin="0,0,10,0" Cursor="Hand" Click="SpecialtyGroupsButton_Click"/>
                    <Button Content="🔍 Найти" Width="150" Height="45" FontSize="16" FontWeight="Bold"
                            Background="#007ACC" Foreground="White" BorderThickness="0"
                            Margin="0,0,10,0" Cursor="Hand" Click="SearchButton_Click"/>
                    <Button Content="🗑 Очистить" Width="150" Height="45" FontSize="16"
                            Background="#6C757D" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="ClearButton_Click"/>
                </StackPanel>

            </StackPanel>

            <!-- === НИЖНЯЯ ЧАСТЬ: РЕЗУЛЬТАТЫ (Пустая, готова к БД) === -->
            <Border Grid.Row="1" Background="White" CornerRadius="5,5,0,0"
                    BorderBrush="#DDD" BorderThickness="1,0,0,0" Margin="20,0,20,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок результатов -->
                    <Border Grid.Row="0" Background="#F8F9FA" Padding="15,10"
                            BorderBrush="#DDD" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="📄 Результаты поиска" FontSize="16" FontWeight="Bold"
                                       Foreground="#333" VerticalAlignment="Center"/>

                            <!-- Кнопки: Отчёт, Добавить студента, Импорт из Excel -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="➕ Студент"
                                        Height="24" Padding="8,3" Margin="0,0,5,0"
                                        Background="#28A745" Foreground="White" BorderThickness="0"
                                        FontSize="11" FontWeight="Normal" Cursor="Hand"
                                        Click="AddStudentButton_Click"
                                        ToolTip="Добавить студента">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Opacity" Value="0.9"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Setter Property="Background" Value="#218838"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="📥 Excel"
                                        Height="24" Padding="8,3" Margin="0,0,5,0"
                                        Background="#FF9800" Foreground="White" BorderThickness="0"
                                        FontSize="11" FontWeight="Normal" Cursor="Hand"
                                        Click="ImportExcelButton_Click"
                                        ToolTip="Импорт из Excel">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Opacity" Value="0.9"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Setter Property="Background" Value="#F57C00"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="📊 Отчёт"
                                        Height="24" Padding="10,3" Margin="0,0,0,0"
                                        Background="#28A745" Foreground="White" BorderThickness="0"
                                        FontSize="11" FontWeight="Normal" Cursor="Hand"
                                        Click="ReportButton_Click"
                                        ToolTip="Отчёт">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Opacity" Value="0.9"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Setter Property="Background" Value="#218838"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <TextBlock Grid.Column="1" x:Name="ResultsCountText" Text="0 записей"
                                       FontSize="14" Foreground="#666"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        </Grid>
                    </Border>

                    <!-- Пустой ItemsControl (заполняется из БД) -->
                    <!-- Пустой ItemsControl (заполняется из БД) -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ResultsItemsControl" Margin="10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- 🔹 ПОДКЛЮЧЕНИЕ PersonItem С ПЕРЕДАЧЕЙ ДАННЫХ -->
                                    <local1:PersonItem PersonData="{Binding}" Margin="0,0,0,10"
                                                       PersonDeleted="PersonItem_PersonDeleted"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 🔹 КНОПКА "НАВЕРХ" (появляется при прокрутке) -->
            <Button x:Name="ScrollToTopButton" Content="↑ Наверх"
                    Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    Width="120" Height="45" FontSize="14" FontWeight="Bold"
                    Background="#007ACC" Foreground="White" BorderThickness="0"
                    Margin="0,0,30,30" Cursor="Hand" Click="ScrollToTopButton_Click"
                    Visibility="Collapsed">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Opacity" Value="0.9"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

        </Grid>
    </ScrollViewer>
</Page>