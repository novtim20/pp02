<Page x:Class="PP02.Label.SpecialtyGroupsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:PP02.Label"
      xmlns:item="clr-namespace:PP02.Label.Item"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="900"
      Background="#F5F5F5"
      Title="Управление группами специальностей"
      Loaded="Page_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ЗАГОЛОВОК -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <Button Content="← Назад" Width="120" Height="35"
                    Background="#607D8B" Foreground="White" FontWeight="Bold" BorderThickness="0"
                    HorizontalAlignment="Left" Margin="0,0,0,15"
                    Click="BackButton_Click"/>

            <TextBlock Text="📚 Управление группами специальностей"
                       FontSize="20" FontWeight="Bold" Foreground="#333"/>
            <TextBlock Text="Добавление, редактирование и удаление групп специальностей и специальностей"
                       FontSize="14" Foreground="#666" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- ОСНОВНАЯ ЧАСТЬ С ТАБАМИ -->
        <TabControl Grid.Row="1" x:Name="MainTabControl"
                    Background="White" BorderBrush="#DDD" BorderThickness="1">

            <!-- Вкладка: Специальности -->
            <TabItem Header="📋 Специальности">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Панель добавления -->
                    <Border Grid.Row="0" Background="#FAFAFA" CornerRadius="5" Padding="15" Margin="0,0,0,15"
                            BorderBrush="#EEE" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="➕ Добавить специальность" FontSize="16" FontWeight="Bold"
                                       Foreground="#333" Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                                    <TextBlock Text="Название *" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <TextBox x:Name="NewSpecialtyNameTextBox" Height="35" Padding="8,0,0,0"
                                             BorderBrush="#DDD" BorderThickness="1"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,10">
                                    <TextBlock Text="Сокращённое название" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <TextBox x:Name="NewSpecialtyShortNameTextBox" Height="35" Padding="8,0,0,0"
                                             BorderBrush="#DDD" BorderThickness="1"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                                    <TextBlock Text="Год добавления" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <TextBox x:Name="NewSpecialtyYearTextBox" Height="35" Padding="8,0,0,0"
                                             BorderBrush="#DDD" BorderThickness="1"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                                    <CheckBox x:Name="NewSpecialtyIsActiveCheckBox" Content="Активная специальность"
                                              IsChecked="True" FontSize="12" Foreground="#555"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="💾 Сохранить специальность" Width="180" Height="40"
                                            Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"
                                            Click="AddSpecialtyButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Список специальностей -->
                    <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="10"
                            BorderBrush="#DDD" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="📝 Существующие специальности"
                                       FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="#333"/>

                            <DataGrid Grid.Row="1" x:Name="SpecialtiesDataGrid"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      IsReadOnly="False" SelectionMode="Single"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="White" BorderBrush="#EEE" BorderThickness="0"
                                      SelectionChanged="SpecialtiesDataGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Сокращение" Binding="{Binding ShortName}" Width="150"/>
                                    <DataGridTextColumn Header="Год" Binding="{Binding ValidFrom, StringFormat={}{0:yyyy}}" Width="80"/>
                                    <DataGridCheckBoxColumn Header="Активна" Binding="{Binding IsActive}" Width="60"/>
                                    <DataGridTemplateColumn Header="Группа" Width="200">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="5,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Привязано к группе"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding GroupId}" Value="{x:Null}">
                                                                    <Setter Property="Text" Value="Не привязана"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding DataContext.SpecialtyGroups, RelativeSource={RelativeSource AncestorType=Page}}"
                                                          SelectedValue="{Binding GroupId, UpdateSourceTrigger=PropertyChanged}"
                                                          DisplayMemberPath="Name"
                                                          SelectedValuePath="Id"
                                                          SelectionChanged="SpecialtyGroupComboBox_SelectionChanged"
                                                          IsEditable="True"
                                                          TextSearch.TextPath="Name">
                                                    <ComboBox.Resources>
                                                        <Style TargetType="ComboBox">
                                                            <Setter Property="Width" Value="180"/>
                                                        </Style>
                                                    </ComboBox.Resources>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Действия" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="✏️" Width="30" Height="25"
                                                            Background="#2196F3" Foreground="White" FontWeight="Bold"
                                                            Click="BtnEditSpecialty_Click"
                                                            Tag="{Binding}"
                                                            ToolTip="Редактировать специальность" Margin="0,0,5,0"/>
                                                    <Button Content="🗑" Width="30" Height="25"
                                                            Background="#F44336" Foreground="White" FontWeight="Bold"
                                                            Click="BtnDeleteSpecialty_Click"
                                                            Tag="{Binding Id}"
                                                            ToolTip="Удалить специальность"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка: Группы специальностей -->
            <TabItem Header="📁 Группы специальностей">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Панель добавления новой группы -->
                    <Border Grid.Row="0" Background="#FAFAFA" CornerRadius="5" Padding="15" Margin="0,0,0,15"
                            BorderBrush="#EEE" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="➕ Добавить группу специальностей" FontSize="16" FontWeight="Bold"
                                       Foreground="#333" Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                                    <TextBlock Text="Название группы *" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <TextBox x:Name="NewGroupNameTextBox" Height="35" Padding="8,0,0,0"
                                             BorderBrush="#DDD" BorderThickness="1"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,10">
                                    <TextBlock Text="Сокращённое название" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <TextBox x:Name="NewGroupShortNameTextBox" Height="35" Padding="8,0,0,0"
                                             BorderBrush="#DDD" BorderThickness="1"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="💾 Сохранить группу" Width="180" Height="40"
                                            Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"
                                            Click="AddGroupButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Список групп специальностей -->
                    <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="10"
                            BorderBrush="#DDD" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="📝 Существующие группы специальностей (отсортированы по дате создания)"
                                       FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="#333"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="SpecialtyGroupsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <item:SpecialtyGroupItem GroupData="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка: Группы (учебные) -->
            <TabItem Header="👥 Группы">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Панель добавления новой группы -->
                    <Border Grid.Row="0" Background="#FAFAFA" CornerRadius="5" Padding="15" Margin="0,0,0,15"
                            BorderBrush="#EEE" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="➕ Добавить учебную группу" FontSize="16" FontWeight="Bold"
                                       Foreground="#333" Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                                    <TextBlock Text="Код группы *" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <TextBox x:Name="NewGroupCodeTextBox" Height="35" Padding="8,0,0,0"
                                             BorderBrush="#DDD" BorderThickness="1"
                                             ToolTip="Например: РП-01-1"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,10">
                                    <TextBlock Text="Сокращение *" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <TextBox x:Name="NewGroupShortNameTextBox2" Height="35" Padding="8,0,0,0"
                                             BorderBrush="#DDD" BorderThickness="1"
                                             ToolTip="Например: РП"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                                    <TextBlock Text="Отображаемое название *" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <TextBox x:Name="NewGroupNameTextBox2" Height="35" Padding="8,0,0,0"
                                             BorderBrush="#DDD" BorderThickness="1"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,10">
                                    <TextBlock Text="Специальность *" FontSize="12" Margin="0,0,0,5" Foreground="#555"/>
                                    <ComboBox x:Name="NewGroupSpecialtyComboBox" Height="35"
                                              BorderBrush="#DDD" BorderThickness="1"
                                              DisplayMemberPath="Name" SelectedValuePath="Id"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,10">
                                    <CheckBox x:Name="NewGroupIsActiveCheckBox" Content="Активная группа"
                                              IsChecked="True" FontSize="12" Foreground="#555"/>
                                </StackPanel>

                                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="💾 Сохранить группу" Width="180" Height="40"
                                            Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"
                                            Click="AddNewGroupButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Список групп -->
                    <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="10"
                            BorderBrush="#DDD" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="📝 Существующие учебные группы"
                                       FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="#333"/>

                            <DataGrid Grid.Row="1" x:Name="GroupsDataGrid"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      IsReadOnly="False" SelectionMode="Single"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="White" BorderBrush="#EEE" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="120"/>
                                    <DataGridTextColumn Header="Сокращение" Binding="{Binding ShortName}" Width="100"/>
                                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Специальность" Binding="{Binding SpecialtyName}" Width="200"/>
                                    <DataGridCheckBoxColumn Header="Активна" Binding="{Binding IsActive}" Width="70"/>
                                    <DataGridTemplateColumn Header="Действия" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="✏️" Width="30" Height="25"
                                                            Background="#2196F3" Foreground="White" FontWeight="Bold"
                                                            Click="BtnEditGroup_Click"
                                                            Tag="{Binding}"
                                                            ToolTip="Редактировать группу" Margin="0,0,5,0"/>
                                                    <Button Content="🗑" Width="30" Height="25"
                                                            Background="#F44336" Foreground="White" FontWeight="Bold"
                                                            Click="BtnDeleteGroup_Click"
                                                            Tag="{Binding Id}"
                                                            ToolTip="Удалить группу"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>