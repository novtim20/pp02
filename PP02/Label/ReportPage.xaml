<Page x:Class="PP02.Label.ReportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:PP02.Label"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1000"
      Title="Формирование отчета">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <!-- Кнопка Назад -->
        <Button Grid.Row="0" Content="← Назад" Width="100" Height="35" HorizontalAlignment="Left"
                Click="BtnBack_Click" Background="#6C757D" Foreground="White" FontWeight="Bold"/>

        <!-- Фильтры -->
        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Роль -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,10">
                    <TextBlock Text="Роль:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbRole" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Специальность -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                    <TextBlock Text="Специальность:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbSpecialty" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Образование -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,10">
                    <TextBlock Text="Образование:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbEducation" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Социальное происхождение -->
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                    <TextBlock Text="Соц. происхождение:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbOrigin" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Социальный статус -->
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,15,10">
                    <TextBlock Text="Соц. статус:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbStatus" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Партийность -->
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                    <TextBlock Text="Партийность:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbParty" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Группа -->
                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,15,10">
                    <TextBlock Text="Группа:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbGroup" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Временной промежуток -->
                <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,10">
                    <TextBlock Text="Временной промежуток (год выпуска):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal">
                        <DatePicker x:Name="DpStartDate" Width="150" SelectedDateChanged="DateFilter_Changed"/>
                        <TextBlock Text=" — " VerticalAlignment="Center" FontWeight="Bold" Margin="5,0"/>
                        <DatePicker x:Name="DpEndDate" Width="150" SelectedDateChanged="DateFilter_Changed"/>
                    </StackPanel>
                </StackPanel>

                <!-- Поиск по ФИО -->
                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,0">
                    <TextBlock Text="Поиск по ФИО:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TbNameSearch" Width="400" HorizontalAlignment="Left" TextChanged="TbNameSearch_TextChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Кнопки экспорта -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,15">
            <Button Content="📊 Экспорт в Excel" Width="150" Height="40" Margin="0,0,15,0"
                    Click="BtnExportExcel_Click" Background="#217346" Foreground="White" FontWeight="Bold"/>
            <Button Content="📄 Экспорт в Word" Width="150" Height="40" Margin="0,0,15,0"
                    Click="BtnExportWord_Click" Background="#2B579A" Foreground="White" FontWeight="Bold"/>
            <Button Content="📕 Экспорт в PDF" Width="150" Height="40" Margin="0,0,15,0"
                    Click="BtnExportPdf_Click" Background="#DC2626" Foreground="White" FontWeight="Bold"/>
            <Button Content="Применить фильтры" Width="150" Height="40" Margin="0,0,0,0"
                    Click="FilterButton_Click" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <!-- Переключатель для документов об образовании -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,15">
            <CheckBox x:Name="ChkIncludeEducationDocuments" Content="Включить документы об образовании"
                      VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
        </StackPanel>

        <!-- Предпросмотр данных -->
        <Border Grid.Row="5" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Предпросмотр данных:" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                <TextBlock x:Name="LbCount" Grid.Row="0" Text="Найдено записей: 0" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" HorizontalAlignment="Right"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ResultsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="{Binding Role}" FontStyle="Italic"/>
                                        <TextBlock Text="{Binding SpecialtyName}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>